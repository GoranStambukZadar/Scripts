[HKEY_LOCAL_MACHINE\SOFTWARE\Classes\SystemFileAssociations\.ps1\Shell\run_edit\shell\002RunwithPSElevated]
"MUIVerb"="Run with PowerShell as administrator"
"HasLUAShield"=""
